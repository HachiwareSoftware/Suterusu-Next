<Window x:Class="Suterusu.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suterusu"
        Width="460"
        Height="700"
        MinWidth="420"
        MinHeight="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        Background="#303030"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI"
        FontSize="13"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush"      Color="#1E1E1E" />
        <SolidColorBrush x:Key="PanelBrush"       Color="#252526" />
        <SolidColorBrush x:Key="BorderBrush"      Color="#3C3C3C" />
        <SolidColorBrush x:Key="TextBrush"        Color="#D4D4D4" />
        <SolidColorBrush x:Key="MutedTextBrush"   Color="#9DA0A6" />
        <SolidColorBrush x:Key="AccentBrush"      Color="#0E639C" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1177BB" />
        <SolidColorBrush x:Key="SelectionBrush"   Color="#094771" />
        <SolidColorBrush x:Key="ErrorBrush"       Color="#A1260D" />
        <SolidColorBrush x:Key="EditPanelBrush"   Color="#1A1A2E" />

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="10" />
            <Setter Property="Margin"          Value="0,0,0,8" />
            <Setter Property="CornerRadius"    Value="2" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="0,0,0,6" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"     Value="0,6,0,2" />
        </Style>

        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin"       Value="0,2,0,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="8,5" />
            <Setter Property="Margin"          Value="0,0,0,4" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="8,5" />
            <Setter Property="Margin"          Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="#1E1E1E" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="6,4" />
            <Setter Property="Margin"          Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#1E1E1E" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding"    Value="6,4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CCE4F7" />
                    <Setter Property="Foreground" Value="#1E1E1E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"                    Value="8,5" />
            <Setter Property="Foreground"                 Value="{StaticResource TextBrush}" />
            <Setter Property="Background"                 Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground"        Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"            Value="0,0,16,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"     Value="0,0,0,4" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#2D2D30" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="12,5" />
            <Setter Property="MinWidth"        Value="60" />
            <Setter Property="Margin"          Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37373D" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3F3F46" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background"  Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding"    Value="12,8" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="12,12,12,0">
            <!-- Chat Tab -->
            <TabItem Header="Chat">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="ChatGPT / Codex (CLI Proxy)" />
                                <TextBlock Style="{StaticResource HintStyle}"
                                           Margin="0,0,0,8"
                                           Text="Connect through browser OAuth, start local proxy, test model, and save to Model Priority in one click." />

                                 <WrapPanel Margin="0,0,0,6">
                                     <Button x:Name="BtnCliProxyConnect"
                                             Style="{StaticResource PrimaryButtonStyle}"
                                             Content="Connect ChatGPT &amp; Use"
                                             Click="OnCliProxyConnectAndUse"
                                             Margin="0,0,6,6" />
                                     <Button x:Name="BtnCliProxyStart"
                                             Style="{StaticResource SecondaryButtonStyle}"
                                             Content="Start"
                                             Click="OnCliProxyStart"
                                             Margin="0,0,6,6" />
                                     <Button x:Name="BtnCliProxyStop"
                                             Style="{StaticResource SecondaryButtonStyle}"
                                             Content="Stop"
                                             Click="OnCliProxyStop"
                                             Margin="0,0,6,6" />
                                     <Button x:Name="BtnCliProxyTest"
                                             Style="{StaticResource SecondaryButtonStyle}"
                                             Content="Test"
                                             Click="OnCliProxyTest"
                                             Margin="0,0,6,6" />
                                     <Button x:Name="BtnCliProxyModels"
                                             Style="{StaticResource SecondaryButtonStyle}"
                                             Content="Detect Models"
                                             Click="OnCliProxyRefreshModels"
                                             Margin="0,0,6,6" />
                                 </WrapPanel>

                                 <!-- CLIProxyAPI version / update controls -->
                                 <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                     <TextBlock x:Name="TxtCliProxyVersion"
                                                Style="{StaticResource HintStyle}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0" />
                                     <Button x:Name="BtnCheckForUpdates"
                                             Style="{StaticResource SecondaryButtonStyle}"
                                             Content="Check for Updates"
                                             Click="OnCheckForUpdates"
                                             Padding="8,2"
                                             Margin="0,0,6,0" />
                                     <Button x:Name="BtnUpdateCliProxy"
                                             Style="{StaticResource SecondaryButtonStyle}"
                                             Content="Install / Update"
                                             Click="OnUpdateCliProxy"
                                             Padding="8,2" />
                                  </StackPanel>

                                  <TextBlock x:Name="TxtCliProxyInstallPath"
                                             Style="{StaticResource HintStyle}"
                                             Margin="0,0,0,8"
                                             TextWrapping="Wrap" />

                                 <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <CheckBox x:Name="ChkCliProxyEnabled"
                                              Grid.Row="0"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              Content="Enable CLI proxy for chat"
                                              Margin="0,0,0,2" />

                                    <CheckBox x:Name="ChkCliProxyAutoStart"
                                              Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              Content="Auto-start with app"
                                              Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Style="{StaticResource LabelStyle}"
                                               Margin="0,0,12,4"
                                               Text="Local endpoint"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="TxtCliProxyEndpoint"
                                             Grid.Row="2"
                                             Grid.Column="1"
                                             IsReadOnly="True" />

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Style="{StaticResource LabelStyle}"
                                               Margin="0,0,12,0"
                                               Text="Status"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="TxtCliProxyStatus"
                                               Grid.Row="3"
                                               Grid.Column="1"
                                               Text="Not configured yet."
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Model Priority" />
                                <ListBox x:Name="LstPriority" Height="100">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Model}" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" Margin="12,0,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Add"    Click="OnAddEntry" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Edit"   Click="OnEditEntry"      Margin="6,0,0,0" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Remove" Click="OnRemoveEntry"    Margin="6,0,0,0" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="↑"      Click="OnMoveEntryUp"    Margin="6,0,0,0" Width="28" MinWidth="0" Padding="4,5" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="↓"      Click="OnMoveEntryDown"  Margin="4,0,0,0" Width="28" MinWidth="0" Padding="4,5" />
                                </StackPanel>
                                <Border x:Name="PnlEntryEdit" Visibility="Collapsed" Background="{StaticResource EditPanelBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="2" Padding="10" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="LblEntryEditTitle" Style="{StaticResource SectionTitleStyle}" FontSize="12" Text="Add Entry" />
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Display Name" />
                                        <TextBox x:Name="TxtEntryName" />
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Preset" />
                                        <ComboBox x:Name="CboEntryPreset" DisplayMemberPath="Name" />
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Base URL" />
                                        <TextBox x:Name="TxtEntryBaseUrl" />
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="API Key" />
                                        <PasswordBox x:Name="PwdEntryApiKey" />
                                         <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                             <TextBlock Style="{StaticResource LabelStyle}" Text="Model" VerticalAlignment="Center" Margin="0" />
                                             <Button x:Name="BtnFetchEntryModels"
                                                     Content="Fetch Models"
                                                     Style="{StaticResource SecondaryButtonStyle}"
                                                     Click="OnFetchEntryModels"
                                                     Margin="8,0,0,0"
                                                     Padding="8,2" />
                                         </StackPanel>
                                         <ComboBox x:Name="CboEntryModel" IsEditable="True" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Style="{StaticResource PrimaryButtonStyle}"   Content="Confirm" Click="OnConfirmEntry" />
                                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Discard" Click="OnDiscardEntry" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Chat Hotkeys" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,0,12,4" Text="Clear chat history" VerticalAlignment="Center" />
                                    <Button Grid.Row="0" Grid.Column="1" x:Name="BtnClearHistoryHotkey" Style="{StaticResource SecondaryButtonStyle}" Click="OnHotkeyButtonClick" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,2,12,4" Text="Read clipboard and send" VerticalAlignment="Center" />
                                    <Button Grid.Row="1" Grid.Column="1" x:Name="BtnSendClipboardHotkey" Style="{StaticResource SecondaryButtonStyle}" Click="OnHotkeyButtonClick" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,2,12,0" Text="Copy last AI response" VerticalAlignment="Center" />
                                    <Button Grid.Row="2" Grid.Column="1" x:Name="BtnCopyLastResponseHotkey" Style="{StaticResource SecondaryButtonStyle}" Click="OnHotkeyButtonClick" />
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="History limit (turns)" />
                                <TextBox x:Name="TxtHistoryLimit" Width="100" HorizontalAlignment="Left" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="System Prompt" />
                                <TextBox x:Name="TxtSystemPrompt" Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Visible" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- OCR Tab -->
            <TabItem Header="OCR">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="OCR Settings" />

                                <TextBlock Style="{StaticResource HintStyle}" Text="Press hotkey, click two points to select screen region. Press hotkey again to cancel." Margin="0,0,0,8" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="OCR Hotkey" />
                                <Button x:Name="BtnOcrHotkey" Style="{StaticResource SecondaryButtonStyle}" Click="OnHotkeyButtonClick" HorizontalAlignment="Left" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Provider" />
                                <ComboBox x:Name="CboOcrProvider" HorizontalAlignment="Left" Width="160"
                                          SelectionChanged="OnOcrProviderChanged" Margin="0,0,0,6" />

                                <!-- llama.cpp settings -->
                                <StackPanel x:Name="PnlLlamaCppSettings">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Server URL" />
                                    <TextBox x:Name="TxtOcrLlamaCppUrl" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Default: http://localhost:8080" />

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Model" VerticalAlignment="Center" />
                                        <Button x:Name="BtnFetchLlamaCppModels" Content="Fetch Models" Click="OnFetchLlamaCppModels" Margin="8,0,0,0" Padding="8,2" />
                                    </StackPanel>
                                    <ComboBox x:Name="CboLlamaCppModel" IsEditable="True" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Select from dropdown or type manually. Requires multimodal vision model." />
                                </StackPanel>

                                <!-- Z.ai settings -->
                                <StackPanel x:Name="PnlZaiSettings" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="API Token" />
                                    <PasswordBox x:Name="PwdOcrZaiToken" />

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Model" />
                                    <TextBox x:Name="TxtOcrZaiModel" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Default: glm-ocr" />
                                </StackPanel>

                                <!-- Custom settings -->
                                <StackPanel x:Name="PnlCustomSettings" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="API Endpoint" />
                                    <TextBox x:Name="TxtOcrCustomUrl" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="OpenAI-compatible endpoint (e.g. https://api.openai.com/v1)" />

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="API Key" />
                                    <PasswordBox x:Name="PwdOcrCustomApiKey" />

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Model" />
                                    <TextBox x:Name="TxtOcrCustomModel" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Vision model name (e.g. gpt-4o-mini)" />
                                </StackPanel>

                                <!-- HuggingFace settings -->
                                <StackPanel x:Name="PnlHfSettings" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="API Endpoint" />
                                    <TextBox x:Name="TxtOcrHfUrl" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Default: https://api.huggingface.co/v1" />

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="API Token" />
                                    <PasswordBox x:Name="PwdOcrHfToken" />

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Model" />
                                    <TextBox x:Name="TxtOcrHfModel" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Default: google/ocr" />
                                </StackPanel>

                                <!-- Windows OCR settings -->
                                <StackPanel x:Name="PnlWindowsOcrSettings" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Recognition Language" />
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="CboWindowsOcrLanguage" Width="280" HorizontalAlignment="Left" />
                                        <Button x:Name="BtnRefreshWindowsOcrLanguages"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Refresh"
                                                Click="OnRefreshWindowsOcrLanguages"
                                                Margin="8,0,0,0"
                                                Padding="8,2" />
                                    </StackPanel>
                                    <TextBlock x:Name="TxtWindowsOcrStatus"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,4,0,0"
                                               Visibility="Collapsed" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Local, offline. No API key required. Max region: 2000×2000 px." />
                                    <TextBlock Style="{StaticResource HintStyle}" Margin="0,4,0,0"
                                               Text="Add language packs via: Settings > Time &amp; Language > Language > Add a language" />
                                </StackPanel>

                                <!-- Prompt row (hidden when Windows OCR is active) -->
                                <StackPanel x:Name="PnlOcrPromptRow">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Prompt" />
                                    <TextBox x:Name="TxtOcrPrompt" />

                                    <CheckBox x:Name="ChkOcrUseClipboardPrompt" Content="Use clipboard text as prompt if not empty" Margin="0,6,0,0" />
                                </StackPanel>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Timeout (ms)" />
                                <TextBox x:Name="TxtOcrTimeoutMs" Width="100" HorizontalAlignment="Left" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Max Tokens" />
                                <TextBox x:Name="TxtOcrMaxTokens" Width="100" HorizontalAlignment="Left" />
                                <TextBlock Style="{StaticResource HintStyle}" Text="Limits response length. Default: 4096." />

                                <CheckBox x:Name="ChkOcrDownscale" Content="Downscale large images before sending" Margin="0,8,0,0" Checked="OnOcrDownscaleChanged" Unchecked="OnOcrDownscaleChanged" />
                                <StackPanel x:Name="PnlOcrMaxDimension" Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Max dimension (px)" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox x:Name="TxtOcrMaxDimension" Width="80" HorizontalAlignment="Left" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource HintStyle}" Text="When downscale is on, images larger than this size are resized. Default: 1024." />

                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Notifications" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <RadioButton x:Name="RbFlashWindow" Content="Flash Window" Checked="OnNotificationModeChanged" />
                                    <RadioButton x:Name="RbCircleDot"   Content="Circle Dot"   Checked="OnNotificationModeChanged" />
                                    <RadioButton x:Name="RbNothing"     Content="Nothing"      Checked="OnNotificationModeChanged" />
                                </StackPanel>

                                <StackPanel x:Name="PnlFlashWindowSettings" Margin="0,0,0,6">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Flash window target" />
                                    <TextBox x:Name="TxtFlashWindowTarget" />
                                    <TextBlock Style="{StaticResource HintStyle}" Text="Process name (e.g. Chrome). 'All' or 'None'." />
                                </StackPanel>

                                <StackPanel x:Name="PnlCircleDotSettings" Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Blink count" />
                                    <TextBox x:Name="TxtCircleDotBlinkCount" Width="100" HorizontalAlignment="Left" />
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Blink duration (ms)" />
                                    <TextBox x:Name="TxtCircleDotBlinkDurationMs" Width="100" HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Multi-Request" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <RadioButton x:Name="RbSequential" Content="Sequential" Checked="OnMultiRequestModeChanged" />
                                    <RadioButton x:Name="RbRoundRobin" Content="Round Robin" Checked="OnMultiRequestModeChanged" />
                                    <RadioButton x:Name="RbFastest"    Content="Fastest"    Checked="OnMultiRequestModeChanged" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Timeout (ms)" />
                                <TextBox x:Name="TxtMultiRequestTimeoutMs" Width="100" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Browser CDP" />
                                <CheckBox x:Name="ChkCdpEnabled" Content="Connect to already-running Chrome DevTools Protocol" />
                                <TextBlock Style="{StaticResource HintStyle}" Text="Does not launch a browser. Connects only to 127.0.0.1 and writes CDP logs to logs/cdp-*.log." Margin="0,0,0,4" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Port" />
                                <TextBox x:Name="TxtCdpPort" Width="100" HorizontalAlignment="Left" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="URL pattern" />
                                <TextBox x:Name="TxtCdpUrlPattern" />
                                <TextBlock Style="{StaticResource HintStyle}" Text="Optional regex used to pick the page target. Empty = first page." />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Event scripts directory" />
                                <TextBox x:Name="TxtCdpStartupScriptsDirectory" />
                                <TextBlock Style="{StaticResource HintStyle}" Text="Default: js/events. Put scripts in onload, onclick, onkeydown, etc. subfolders." />

                                <CheckBox x:Name="ChkCdpInjectOnStartup" Content="Inject event scripts persistently and evaluate current page once" Margin="0,6,0,0" />

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Retry interval (ms)" />
                                        <TextBox x:Name="TxtCdpRetryIntervalMs" Width="120" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Connect timeout (ms)" />
                                        <TextBox x:Name="TxtCdpConnectTimeoutMs" Width="120" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Application" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Quit Hotkey" />
                                <Button x:Name="BtnQuitApplicationHotkey" Style="{StaticResource SecondaryButtonStyle}" Click="OnHotkeyButtonClick" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Validation -->
        <Border x:Name="ValidationErrorBar" Grid.Row="0"
                Style="{StaticResource SectionBorderStyle}"
                BorderBrush="{StaticResource ErrorBrush}"
                Background="#2D1A1A"
                Visibility="Collapsed"
                VerticalAlignment="Bottom"
                Margin="12,0,12,12">
            <TextBlock x:Name="LblValidationError" TextWrapping="Wrap" />
        </Border>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="#252526"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,1,0,0"
                Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PrimaryButtonStyle}"   Content="Save"   Click="OnSave" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Click="OnCancel" Margin="6,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
