<Window x:Class="Suterusu.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suterusu"
        Width="460"
        Height="780"
        MinWidth="420"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#303030"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI"
        FontSize="13"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush"      Color="#1E1E1E" />
        <SolidColorBrush x:Key="PanelBrush"       Color="#252526" />
        <SolidColorBrush x:Key="BorderBrush"      Color="#3C3C3C" />
        <SolidColorBrush x:Key="TextBrush"        Color="#D4D4D4" />
        <SolidColorBrush x:Key="MutedTextBrush"   Color="#9DA0A6" />
        <SolidColorBrush x:Key="AccentBrush"      Color="#0E639C" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1177BB" />
        <SolidColorBrush x:Key="SelectionBrush"   Color="#094771" />
        <SolidColorBrush x:Key="ErrorBrush"       Color="#A1260D" />
        <SolidColorBrush x:Key="EditPanelBrush"   Color="#1A1A2E" />

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="10" />
            <Setter Property="Margin"          Value="0,0,0,8" />
            <Setter Property="CornerRadius"    Value="2" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="0,0,0,6" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"     Value="0,6,0,2" />
        </Style>

        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin"       Value="0,2,0,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="8,5" />
            <Setter Property="Margin"          Value="0,0,0,4" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="8,5" />
            <Setter Property="Margin"          Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="#1E1E1E" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="6,4" />
            <Setter Property="Margin"          Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#1E1E1E" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding"    Value="6,4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CCE4F7" />
                    <Setter Property="Foreground" Value="#1E1E1E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#1B1B1C" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"                    Value="8,5" />
            <Setter Property="Foreground"                 Value="{StaticResource TextBrush}" />
            <Setter Property="Background"                 Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground"        Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"            Value="0,0,16,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#2D2D30" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="12,5" />
            <Setter Property="MinWidth"        Value="60" />
            <Setter Property="Margin"          Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37373D" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3F3F46" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background"  Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      Padding="12">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Settings" Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource HintStyle}" Margin="0,0,0,12"
                           Text="Configure model priority, behavior, and notifications." />

                <!-- Model Priority -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Model Priority" />
                        <TextBlock Style="{StaticResource HintStyle}" Margin="0,0,0,6"
                                   Text="Models are tried top-to-bottom (Sequential), rotated (Round Robin), or raced (Fastest). Each entry has its own endpoint and API key." />

                        <!-- Priority list -->
                        <ListBox x:Name="LstPriority" Height="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Model}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="12,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- List action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Add"    Click="OnAddEntry" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Edit"   Click="OnEditEntry"      Margin="6,0,0,0" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Remove" Click="OnRemoveEntry"    Margin="6,0,0,0" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="↑"      Click="OnMoveEntryUp"    Margin="6,0,0,0" Width="28" MinWidth="0" Padding="4,5" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="↓"      Click="OnMoveEntryDown"  Margin="4,0,0,0" Width="28" MinWidth="0" Padding="4,5" />
                        </StackPanel>

                        <!-- Inline add / edit form -->
                        <Border x:Name="PnlEntryEdit"
                                Visibility="Collapsed"
                                Background="{StaticResource EditPanelBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="10"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock x:Name="LblEntryEditTitle"
                                           Style="{StaticResource SectionTitleStyle}"
                                           FontSize="12"
                                           Text="Add Entry" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Display Name" />
                                <TextBox x:Name="TxtEntryName" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Preset" />
                                <ComboBox x:Name="CboEntryPreset"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="OnEntryPresetChanged" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Base URL" />
                                <TextBox x:Name="TxtEntryBaseUrl" TextChanged="OnEntryBaseUrlChanged" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="API Key (leave blank if not needed)" />
                                <PasswordBox x:Name="PwdEntryApiKey" />

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Model" />
                                <TextBox x:Name="TxtEntryModel" />

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Style="{StaticResource PrimaryButtonStyle}"   Content="Confirm" Click="OnConfirmEntry" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Discard" Click="OnDiscardEntry" Margin="6,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Behavior -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Behavior" />

                        <TextBlock Style="{StaticResource LabelStyle}" Text="History limit (turns)" />
                        <TextBox x:Name="TxtHistoryLimit" Width="100" HorizontalAlignment="Left" />

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Notification mode" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton x:Name="RbFlashWindow" Content="Flash Window"
                                         Checked="OnNotificationModeChanged" />
                            <RadioButton x:Name="RbCircleDot"   Content="Circle Dot"
                                         Checked="OnNotificationModeChanged" />
                            <RadioButton x:Name="RbNothing"     Content="Nothing"
                                         Checked="OnNotificationModeChanged" />
                        </StackPanel>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Multi-request mode" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton x:Name="RbSequential" Content="Sequential (fallback)"
                                         Checked="OnMultiRequestModeChanged" />
                            <RadioButton x:Name="RbRoundRobin" Content="Round Robin"
                                         Checked="OnMultiRequestModeChanged" />
                            <RadioButton x:Name="RbFastest"    Content="Fastest (race)"
                                         Checked="OnMultiRequestModeChanged" />
                        </StackPanel>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Multi-request timeout (ms)" />
                        <TextBox x:Name="TxtMultiRequestTimeoutMs" Width="100" HorizontalAlignment="Left" />

                        <!-- Flash Window settings -->
                        <StackPanel x:Name="PnlFlashWindowSettings" Margin="0,0,0,6">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Flash window target" />
                            <TextBox x:Name="TxtFlashWindowTarget" />
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="Process name to flash (e.g. Chrome). Use 'All' for all windows or 'None' to disable." />
                        </StackPanel>

                        <!-- Circle Dot settings -->
                        <StackPanel x:Name="PnlCircleDotSettings" Margin="0,0,0,6" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Blink count" />
                            <TextBox x:Name="TxtCircleDotBlinkCount" Width="100" HorizontalAlignment="Left" />
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="How many times the dot blinks (1–10)." />

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Blink duration (ms)" />
                            <TextBox x:Name="TxtCircleDotBlinkDurationMs" Width="100" HorizontalAlignment="Left" />
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="Total duration of all blinks (200–5000 ms)." />
                        </StackPanel>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="System Prompt" />
                        <TextBox x:Name="TxtSystemPrompt"
                                 Height="120"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Visible" />
                    </StackPanel>
                </Border>

                <!-- Validation -->
                <Border x:Name="ValidationErrorBar"
                        Style="{StaticResource SectionBorderStyle}"
                        BorderBrush="{StaticResource ErrorBrush}"
                        Background="#2D1A1A"
                        Visibility="Collapsed">
                    <TextBlock x:Name="LblValidationError" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="#252526"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,1,0,0"
                Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PrimaryButtonStyle}"   Content="Save"   Click="OnSave" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Click="OnCancel" Margin="6,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
