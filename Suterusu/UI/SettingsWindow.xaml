<Window x:Class="Suterusu.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suterusu"
        Width="440"
        Height="680"
        MinWidth="400"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#303030"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI"
        FontSize="13"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush"    Color="#1E1E1E" />
        <SolidColorBrush x:Key="PanelBrush"     Color="#252526" />
        <SolidColorBrush x:Key="BorderBrush"    Color="#3C3C3C" />
        <SolidColorBrush x:Key="TextBrush"      Color="#D4D4D4" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9DA0A6" />
        <SolidColorBrush x:Key="AccentBrush"    Color="#0E639C" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1177BB" />
        <SolidColorBrush x:Key="SelectionBrush" Color="#094771" />
        <SolidColorBrush x:Key="ErrorBrush"     Color="#A1260D" />

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="10" />
            <Setter Property="Margin"           Value="0,0,0,8" />
            <Setter Property="CornerRadius"     Value="2" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="14" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="Margin"       Value="0,0,0,6" />
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"       Value="0,6,0,2" />
        </Style>

        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin"       Value="0,2,0,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="#1B1B1C" />
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="8,5" />
            <Setter Property="Margin"           Value="0,0,0,4" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background"       Value="#1B1B1C" />
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="8,5" />
            <Setter Property="Margin"           Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="#1B1B1C" />
            <Setter Property="Foreground"       Value="#1E1E1E" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="6,4" />
            <Setter Property="Margin"           Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#1E1E1E" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding"    Value="6,4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CCE4F7" />
                    <Setter Property="Foreground" Value="#1E1E1E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background"       Value="#1B1B1C" />
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"                  Value="8,5" />
            <Setter Property="Foreground"               Value="{StaticResource TextBrush}" />
            <Setter Property="Background"               Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"           Value="0,0,16,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#2D2D30" />
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="12,5" />
            <Setter Property="MinWidth"         Value="80" />
            <Setter Property="Margin"           Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37373D" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3F3F46" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background"   Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush"  Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      Padding="12">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Settings" Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource HintStyle}" Margin="0,0,0,12"
                           Text="Configuration for endpoint, models, and behavior." />

                <!-- Endpoint -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Endpoint" />

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Preset" />
                        <ComboBox x:Name="CboEndpointPresets"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="OnPresetChanged" />

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Base URL" />
                        <TextBox x:Name="TxtBaseUrl" TextChanged="OnBaseUrlChanged" />

                        <TextBlock Style="{StaticResource LabelStyle}" Text="API Key" />
                        <PasswordBox x:Name="PwdApiKey" />
                    </StackPanel>
                </Border>

                <!-- Models -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Models" />
                        <TextBlock Style="{StaticResource HintStyle}" Margin="0,0,0,6"
                                   Text="F7 tries each model in order and falls back on failure." />

                        <ListBox x:Name="LstModels" Height="60" />

                        <Grid Margin="0,6,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewModel" Grid.Column="0" Margin="0,0,6,0" KeyDown="OnNewModelKeyDown" />
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="+" Click="OnAddModel" Width="28" />
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Move Up"   Click="OnMoveModelUp" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Move Down" Click="OnMoveModelDown" Margin="6,0,0,0" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Remove"    Click="OnRemoveModel"  Margin="6,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Behavior -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Behavior" />

                        <TextBlock Style="{StaticResource LabelStyle}" Text="History limit (turns)" />
                        <TextBox x:Name="TxtHistoryLimit" Width="100" HorizontalAlignment="Left" />

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Notification mode" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton x:Name="RbFlashWindow" Content="Flash Window"
                                         Checked="OnNotificationModeChanged" />
                            <RadioButton x:Name="RbCircleDot"   Content="Circle Dot"
                                         Checked="OnNotificationModeChanged" />
                            <RadioButton x:Name="RbNothing"     Content="Nothing"
                                         Checked="OnNotificationModeChanged" />
                        </StackPanel>

                        <!-- Flash Window settings — shown only when Flash Window is selected -->
                        <StackPanel x:Name="PnlFlashWindowSettings" Margin="0,0,0,6">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Flash window target" />
                            <TextBox x:Name="TxtFlashWindowTarget" />
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="Process name to flash (e.g. Chrome). Use 'All' for all windows or 'None' to disable." />
                        </StackPanel>

                        <!-- Circle Dot settings — shown only when Circle Dot is selected -->
                        <StackPanel x:Name="PnlCircleDotSettings" Margin="0,0,0,6" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Pulse duration (ms)" />
                            <TextBox x:Name="TxtCircleDotPulseMs" Width="100" HorizontalAlignment="Left" />
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="How long the dot is visible and pulsing (200–5000 ms). The sine animation always completes two full cycles in this period." />
                        </StackPanel>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="System Prompt" />
                        <TextBox x:Name="TxtSystemPrompt"
                                 Height="120"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Visible" />
                    </StackPanel>
                </Border>

                <!-- Validation -->
                <Border x:Name="ValidationErrorBar"
                        Style="{StaticResource SectionBorderStyle}"
                        BorderBrush="{StaticResource ErrorBrush}"
                        Background="#2D1A1A"
                        Visibility="Collapsed">
                    <TextBlock x:Name="LblValidationError" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="#252526"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,1,0,0"
                Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PrimaryButtonStyle}"   Content="Save"   Click="OnSave" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Click="OnCancel" Margin="6,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
